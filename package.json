{
  "name": "@nutzy/schema",
  "version": "3.0.1",
  "description": "Zod schemas and inferred TypeScript types for Nutzy jobs and companies",
  "license": "MIT",
  "author": "Pieter <pieter@nutzy.nl>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Purple-Squirrel-Effect/nutzy-schema.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./job.schema.json": "./dist/job.schema.json",
    "./company.schema.json": "./dist/company.schema.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/emit-json-schemas.cjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "zod": ">=3.25"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
